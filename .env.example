# DashScope API Key (阿里云百炼/通义千问)
# 用于内容生成 (LLM) 和封面生成 (Wanx/Qwen-VL)
# 获取地址: https://bailian.console.aliyun.com/
DASHSCOPE_API_KEY=sk-your_dashscope_api_key_here

# 微信公众号配置 (WeChat Official Account)
# 用于自动同步草稿箱 (仅当使用 --sync 参数时需要)
# 获取地址: 微信公众平台 -> 开发 -> 基本配置
WECHAT_APP_ID=your_wechat_app_id
WECHAT_APP_SECRET=your_wechat_app_secret

# 小红书配置 (Xiaohongshu)
# 可选: 设置为 1 以显示浏览器界面 (非无头模式)，便于调试或扫码登录
# 默认情况下脚本会尝试使用 cookies.json 自动登录，如果失败则会生成二维码图片
XHS_ALLOW_NON_HEADLESS=0
